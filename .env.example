# Database
DATABASE_URL="postgresql://user:password@host:5432/alina_parking?schema=public&sslmode=require"

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Alina Visitor Parking"

# Resend Email Service
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="parking@yourdomain.com"
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Online License Plate Recognition (recommended for patrol mode)
PLATE_RECOGNIZER_API_TOKEN=""
PLATE_RECOGNIZER_API_URL="https://api.platerecognizer.com/v1/plate-reader/"
PLATE_RECOGNIZER_REGION_HINTS="ca-bc,ca,us,mx"
PLATE_RECOGNIZER_STRICT_REGION="false"

# Rate Limiting (Upstash Redis) - Optional
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry Error Monitoring - Optional
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS="true"
ENABLE_RATE_LIMITING="false"
ENABLE_ANALYTICS="true"

# Security
ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# Environment
NODE_ENV="development"
